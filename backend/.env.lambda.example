# backend/.env.lambda.example
# Environment variables required by the API Lambda function.
# These are set in CDK ApiStack — this file is documentation only.

POWERTOOLS_SERVICE_NAME=mike-api
POWERTOOLS_LOG_LEVEL=INFO
SUPABASE_SECRET_ARN=arn:aws:secretsmanager:eu-west-1:123456789012:secret:mike/supabase-XXXXXX
S3_BUCKET_NAME=mike-documents-bucket-name
FRONTEND_URL=https://dXXXXXXXXXXXXX.cloudfront.net

# Set automatically by Lambda runtime — do not configure manually:
# AWS_REGION
# AWS_LAMBDA_FUNCTION_NAME
