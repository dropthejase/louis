# backend/.env.lambda.example
# Environment variables required by the API Lambda function.
# These are set in CDK ApiStack — this file is documentation only.

DB_CLUSTER_ARN=arn:aws:rds:eu-west-1:123456789012:cluster:mike-cluster-XXXXXX
DB_SECRET_ARN=arn:aws:secretsmanager:eu-west-1:123456789012:secret:mike-db-secret-XXXXXX
DB_NAME=mike
DOCS_BUCKET_NAME=mike-documents-bucket-name
SESSIONS_BUCKET_NAME=mike-sessions-bucket-name
USER_POOL_ID=eu-west-1_XXXXXXXXX
FRONTEND_URL=https://dXXXXXXXXXXXXX.cloudfront.net
CREDITS_TABLE_NAME=mike-credits-XXXXXX
NODE_ENV=production
POWERTOOLS_SERVICE_NAME=mike-api
POWERTOOLS_LOG_LEVEL=INFO

# Set automatically by Lambda runtime — do not configure manually:
# AWS_REGION
# AWS_LAMBDA_FUNCTION_NAME
